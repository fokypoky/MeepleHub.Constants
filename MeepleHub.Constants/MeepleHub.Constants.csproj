<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>

		<GeneratePackageOnBuild>true</GeneratePackageOnBuild>
		<PackageId>MeppleHub.Constants</PackageId>
		<Version>1.1.0</Version>
		<Authors>fokypoky</Authors>
		<Description>Shared constants in MeepleHub project</Description>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageProjectUrl>https://github.com/fokypoky/MeepleHub.Constants</PackageProjectUrl>
		<RepositoryUrl>https://github.com/fokypoky/MeepleHub.Constants</RepositoryUrl>
		<GenrateDocumentationFile>true</GenrateDocumentationFile>
	</PropertyGroup>

</Project>
